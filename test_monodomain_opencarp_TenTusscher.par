# ==========================================
# 1. SETUP GENERALE E MESH
# ==========================================
simID                                   = test_monodomain_tentusscher1
meshname                                = ./503kaggle500_opencarpmesh/503kaggle500_opencarp
tend                                    = 500.0   # 500 ms bastano per vedere un battito completo
spacedt                                 = 1.0     # Salva l'output 3D ogni 1 ms
timedt                                  = 1.0
dt                                      = 25 

bidomain                                = 0       # 0 = Monodominio
parab_solve                             = 1
mass_lumping                            = 0

# Attiva il recupero del segnale nei punti specificati (PSEUDO ECG)
phie_rec_ptf = electrode_location_test.pts
# Nome file di output
phie_recovery_file = phie_recovery_test

# ==========================================
# 2. PROPRIETÀ DI CONDUZIONE
# ==========================================
# Valori tipici di conduttività in S/m. 
num_gregions                            = 1

gregion[0].name                         = "Miocardio"
gregion[0].num_IDs                      = 3
gregion[0].ID[0]                        = 1
gregion[0].ID[1]                        = 2
gregion[0].ID[2]                        = 3

# conduttività intracellulari
gregion[0].g_il                         = 0.174
gregion[0].g_it                         = 0.019
gregion[0].g_in                         = 0.019

# ==========================================
# 3. ETEROGENEITÀ CELLULARE (tenTusscherPanfilov)
# ==========================================
num_imp_regions                         = 3

# --- REGIONE 1: ENDOCARDIO ---
imp_region[0].name                      = Endocardio
imp_region[0].num_IDs                   = 1
imp_region[0].ID[0]                     = 1       # tag per endo
imp_region[0].im                        = tenTusscherPanfilov
imp_region[0].im_param                  = "cell_type=ENDO"  # cellula endo in ToRORd

# --- REGIONE 2: MID-MIOCARDIO (M-CELLS) ---
imp_region[1].name                      = Mid_Miocardio
imp_region[1].num_IDs                   = 1
imp_region[1].ID[0]                     = 2       # Tag per mid-miocardio
imp_region[1].im                        = tenTusscherPanfilov
imp_region[1].im_param                  = "cell_type=MCELL"  # cellula M

# --- REGIONE 3: EPICARDIO ---
imp_region[2].name                      = Epicardio
imp_region[2].num_IDs                   = 1
imp_region[2].ID[0]                     = 3       # Tag per epicardio
imp_region[2].im                        = tenTusscherPanfilov
imp_region[2].im_param                  = "cell_type=EPI"  # cellula epi

# Tutte le regioni appartengono al dominio intracellulare
num_phys_regions                        = 1
phys_region[0].ptype                    = 2
phys_region[0].name                     = "Intracellular domain"
phys_region[0].num_IDs                  = 3
phys_region[0].ID[0]                    = 1
phys_region[0].ID[1]                    = 2
phys_region[0].ID[2]                    = 3

# ==========================================
# 4. STIMOLAZIONE (ROOT NODES)
# ==========================================
num_stim                                = 21

# Root Node 1
stim[0].name                            = RN1
stim[0].elec.vtx_file                   = ./activation_sites/RN1.vtx
stim[0].ptcl.duration                   = 2.0
stim[0].ptcl.npls                       = 1
stim[0].ptcl.start                      = 45.0515   # Delay time 
stim[0].pulse.strength                  = 250.0 # Valore tipico per stimoli intracellulari
stim[0].crct.type                       = 0

